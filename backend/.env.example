# ─── Required in Production (Render) ──────────────────────────────────────────
# Public direct-download URL for cleaned_data.csv (Google Drive, Dropbox, etc.)
# Get this by uploading the file to Google Drive → Share → Anyone with link →
# then use: https://drive.google.com/uc?export=download&id=<FILE_ID>
CSV_URL=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example:  https://your-app.vercel.app,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ─── Optional ─────────────────────────────────────────────────────────────────
PORT=3001
